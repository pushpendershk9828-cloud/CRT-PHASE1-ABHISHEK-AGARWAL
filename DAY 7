//Program --3
//Protected access specifier

#include<iostream>
using namespace std;

class Parent {
    protected:
    int secretcode = 1234;
};

class child: Parent {
    public:
    void accessLocker(){
        cout<<secretcode;
    }
};

int main() {
    child obj1;
    obj1.accessLocker();
}

