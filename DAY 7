//private

#include<iostream>
using namespace std;

class BankAccount{
    private:
    int balance=5000;
    public:
    void showBalance(){
        cout<<balance;
    }
};
int main() {
    BankAccount obj1;
    obj1.showBalance();
}

//Program --3
//Protected access specifier

#include<iostream>
using namespace std;

class Parent {
    protected:
    int secretcode = 1234;
};

class child: Parent {
    public:
    void accessLocker(){
        cout<<secretcode;
    }
};

int main() {
    child obj1;
    obj1.accessLocker();
}
